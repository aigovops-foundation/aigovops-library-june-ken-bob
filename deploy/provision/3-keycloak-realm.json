{
  "realm": "aigovops",
  "enabled": true,
  "displayName": "AiGovOps Foundation",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "sslRequired": "external",
  "groups": [
    { "name": "steward" },
    { "name": "member" }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": { "claim.name": "groups", "full.path": "false", "id.token.claim": "true", "access.token.claim": "true", "userinfo.token.claim": "true" }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "aigov-console",
      "name": "AiGovOps Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "CHANGEME-rotate-after-import",
      "redirectUris": [
        "https://console.aigovops.org/auth/oidc/callback",
        "http://localhost:8787/auth/oidc/callback"
      ],
      "webOrigins": ["+"],
      "defaultClientScopes": ["openid", "email", "profile", "groups"]
    }
  ]
}
