# deploy/.env.1password.tmpl — EVERY backend credential as a 1Password reference.
# No secret values live here; only op:// pointers. Render with the 1Password CLI:
#
#   op inject -i deploy/.env.1password.tmpl -o .env       # writes a resolved .env
#   # or run a process with secrets injected and NEVER written to disk:
#   op run --env-file=deploy/.env.1password.tmpl -- node core/src/server.js
#
# Auth (operator step): set OP_SERVICE_ACCOUNT_TOKEN (no-paste, automatable) or
# `op signin`. Items live in the "AiGovOps" vault, one item per scope/service.

# --- core / sessions ---
SESSION_SECRET=op://AiGovOps/session/secret
STEWARD_TOKEN=op://AiGovOps/ops/steward-token

# --- secrets broker profile (api keys brokered, never handed to agents) ---
SECRETS_PROFILE=1password
OP_VAULT=AiGovOps
OP_FIELD=credential

# --- identity (OIDC / Keycloak) ---
OIDC_ISSUER=https://id.aigovops.org/realms/aigovops
OIDC_CLIENT_ID=aigov-console
OIDC_CLIENT_SECRET=op://AiGovOps/oidc/client-secret

# --- datastores ---
DATABASE_URL=op://AiGovOps/postgres/url
REDIS_URL=op://AiGovOps/redis/url

# --- Vault (enclave broker backend) ---
VAULT_ADDR=https://vault.internal:8200
VAULT_TOKEN=op://AiGovOps/vault/token

# --- model (cloud is opt-in; key from 1Password when used) ---
ALLOW_CLOUD=false
# LLM_CLOUD_URL=https://api.openai.com/v1
# LLM_CLOUD_MODEL=gpt-4o-mini
# LLM_CLOUD_KEY=op://AiGovOps/llm/cloud-key

# --- Beacon signing key (prod: from 1Password/KMS, not ./keys files) ---
# BEACON_PRIVATE_KEY_PEM=op://AiGovOps/beacon/private-key
# BEACON_PUBLIC_KEY_PEM=op://AiGovOps/beacon/public-key

# --- Hermes messenger (dashboard is always on; enable channels as needed) ---
# Channel tokens are brokered (op:// refs), never handed to an agent.
NOTIFY_CHANNELS=dashboard
# Telegram (outbound alerts + the two-way founder bridge):
# NOTIFY_TELEGRAM_TOKEN=op://AiGovOps/notify-telegram/credential   # from BotFather
# NOTIFY_TELEGRAM_TO=                 # default chat id for outbound
# NOTIFY_TELEGRAM_FOUNDERS=123456789:bob,987654321:ken            # telegram_id:steward
# NOTIFY_TELEGRAM_WEBHOOK_SECRET=op://AiGovOps/notify-telegram/webhook-secret
# Email (Postmark-shape HTTP API):
# NOTIFY_EMAIL_TOKEN=op://AiGovOps/notify-email/credential
# NOTIFY_EMAIL_FROM=hermes@aigovops.org
# Twilio (SMS + voice share one account):
# NOTIFY_TWILIO_SID=op://AiGovOps/notify-twilio/sid
# NOTIFY_TWILIO_TOKEN=op://AiGovOps/notify-twilio/credential
# NOTIFY_TWILIO_FROM=+10000000000
