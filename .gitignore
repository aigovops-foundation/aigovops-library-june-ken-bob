node_modules/
.env
core/.env
core/keys/*.pem
# ALL keys, at any depth — not just core/keys/. The original rule covered core/keys/ only,
# so the dev keypair at the repo ROOT (keys/private.pem) was committed to a PUBLIC repo on
# 2026-06-08 and sat in HEAD for six weeks. keygen.mjs even told us it was "gitignored".
# A rule that protects one directory reads like a rule that protects keys, right up until
# someone puts a key somewhere else.
keys/*.pem
**/keys/*.pem
*.pem
!keys/.gitkeep
core/ledger/*.ndjson
*.log
.DS_Store

# secret broker backing store (FileProvider) — NEVER commit
secrets.local.json
core/secrets.local.json

# exported evidence bundles (shared with auditors, not committed)
evidence-bundle/
core/evidence-bundle/

# rendered deploy secrets (from 1Password) — NEVER commit
deploy/.env
deploy/.dead-simple.state

# rendered enclave config — the human pastes real secrets into it on the host
deploy/enclave/*.env
deploy/enclave/.enclave-up.state

# stray nested runtime ledger artifact (runtime data, not source)
core/core/

# local dev-server config (machine-specific absolute paths)
.claude/launch.json

# voice-casting samples (not for deploy)
docs/audio/onboarding/samples/

# video render scratch (intermediate clips)
docs/audio/onboarding/.build/

# the rendered tour video — too large for git/Pages; host on YouTube/Vimeo
docs/audio/onboarding/*.mp4
