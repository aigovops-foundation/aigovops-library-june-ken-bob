# core/profiles/enclave.env.example — the hardened ENCLAVE posture (Ticket 9).
# Copy into your secret store / orchestrator; assertEnclave() refuses to serve if
# any of these is weaker. NO SECRETS IN THIS FILE — only the core reads the real
# values from Vault / the secret store at runtime.

# Secrets brokered by Vault in-perimeter (T2) — never a local file.
SECRETS_PROFILE=enclave
VAULT_ADDR=https://vault.internal:8200
# VAULT_TOKEN comes from the orchestrator's secret store, not this file.
VAULT_KV_MOUNT=secret

# Kernel-level tool isolation (T4) — requires Docker + the runsc runtime (Linux).
SANDBOX_BACKEND=gvisor
SANDBOX_IMAGE=node:20-alpine
SANDBOX_EGRESS_NET=aigov-egress
# Egress DENY-ALL: leave empty. Tools get only the hosts they declare per-run.
SANDBOX_DEFAULT_EGRESS=

# Internal models only — no cloud egress.
ALLOW_CLOUD=false

# Yes-Gate rules as signed rego bundles (T7) — needs the `opa` binary on PATH.
POLICY_ENGINE=opa

# Identity via an in-perimeter OIDC IdP (T8), e.g. Keycloak.
OIDC_ISSUER=https://id.internal/realms/aigovops
OIDC_CLIENT_ID=aigov-console
# OIDC_CLIENT_SECRET from the secret store.
OIDC_REDIRECT_URI=https://console.internal/auth/oidc/callback
OIDC_STEWARD_GROUP=steward

# Durable ledger home — in-VPC Postgres (private host only).
DATABASE_URL=postgres://aigov@db.internal:5432/aigov

# Beacon signing key from a KMS/secret store (not ./keys files in an enclave).
# BEACON_PRIVATE_KEY_PEM / BEACON_PUBLIC_KEY_PEM
