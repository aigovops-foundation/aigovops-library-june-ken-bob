# Copy to .env. NO SECRETS BELONG IN ANY CLIENT — only the core reads these.
PORT=8787
DEFAULT_LOCALE=en
# CORS allow-list (comma-separated). Add your room/site origins here.
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787
# Cloud models are OFF by default — local-first, $0, private.
ALLOW_CLOUD=false
# In production, provide keys from a KMS/secret store instead of ./keys files:
# BEACON_PRIVATE_KEY_PEM=
# BEACON_PUBLIC_KEY_PEM=

# --- Auth (GitHub OAuth) — gates write endpoints (decide/run/skills) ---------
# Create a GitHub OAuth app; set callback to https://<host>/auth/callback.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=          # set as a secret in prod (fly secrets set …)
# OAUTH_REDIRECT_URI=https://<host>/auth/callback
STEWARDS=                        # comma-separated GitHub logins that get the steward role
# SESSION_SECRET=                # HMAC key for session cookies (set a stable value in prod)
# STEWARD_TOKEN=                 # optional ops bearer token (admin escape hatch)
# LOCAL DEV ONLY — treat every caller as a steward so the console works without OAuth:
# AUTH_DISABLED=true

# --- LLM router (Ollama, local-first) ---------------------------------------
# OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b         # used when Ollama is reachable; else falls back to the built-in stub

# --- Storage (dual): file ledger by default; Postgres when DATABASE_URL is set
# Enabling Postgres adds the one dependency `pg` (npm i pg) — opt-in, keeps the default dependency-free.
# DATABASE_URL=postgres://user:pass@host:5432/aigov
