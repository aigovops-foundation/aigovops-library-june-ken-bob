# Copy to .env. NO SECRETS BELONG IN ANY CLIENT — only the core reads these.
PORT=8787
DEFAULT_LOCALE=en
# CORS allow-list (comma-separated). Add your room/site origins here.
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787
# Cloud models are OFF by default — local-first, $0, private.
ALLOW_CLOUD=false
# In production, provide keys from a KMS/secret store instead of ./keys files:
# BEACON_PRIVATE_KEY_PEM=
# BEACON_PUBLIC_KEY_PEM=

# --- Auth (GitHub OAuth) — gates write endpoints (decide/run/skills) ---------
# Create a GitHub OAuth app; set callback to https://<host>/auth/callback.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=          # set as a secret in prod (fly secrets set …)
# OAUTH_REDIRECT_URI=https://<host>/auth/callback
STEWARDS=                        # comma-separated GitHub logins that get the steward role
# Per-member capability profiles (#6): seed dials without a live login. JSON array
# of { id, role, level? } — members onboard narrow (propose) by default otherwise.
# AIGOV_MEMBERS=[{"id":"oidc:ken","role":"steward"},{"id":"oidc:alice","role":"member","level":"act"}]
# SESSION_SECRET=                # HMAC key for session cookies (set a stable value in prod)
# STEWARD_TOKEN=                 # optional ops bearer token (admin escape hatch)
# LOCAL DEV ONLY — treat every caller as a steward so the console works without OAuth:
# AUTH_DISABLED=true

# --- Auth (OIDC) — provider-agnostic standards login (Ticket 8) --------------
# Works with any compliant IdP via discovery. DEFAULT CHOICE: Keycloak (self-host,
# aligns with the enclave "run-it-yourself" principle); Auth0/Okta/Entra/Google
# work with the same three vars. Role = steward iff the id_token carries the
# steward group/role OR the username is on STEWARDS (above).
# OIDC_ISSUER=https://id.aigovops.org/realms/aigovops   # discovery base (/.well-known/openid-configuration)
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=            # set as a secret in prod
# OIDC_REDIRECT_URI=https://<host>/auth/oidc/callback
# OIDC_SCOPE=openid email profile
# OIDC_STEWARD_GROUP=steward    # claim group/role that grants the steward role

# --- Secrets broker profile (Ticket 0/2) — config-only swap -------------------
# lab (default): FileProvider. community/enclave: Vault. 1password: OnePassword.
# SECRETS_PROFILE=lab
# 1Password profile (api keys live in a 1Password vault, brokered as scoped tokens):
# SECRETS_PROFILE=1password
# OP_VAULT=AiGovOps               # vault holding one item per scope
# OP_FIELD=credential             # field on each item holding the secret
# OP_SERVICE_ACCOUNT_TOKEN=       # no-paste automation auth (else `op signin`)
# Any var below may ALSO be an op:// reference; the core resolves it at boot, e.g.
#   SESSION_SECRET=op://AiGovOps/session/secret
#   DATABASE_URL=op://AiGovOps/postgres/url
# SECRETS_FILE=./secrets.local.json   # FileProvider backing store (gitignored)
# VaultProvider (SECRETS_PROFILE=community|enclave) needs a reachable Vault:
# VAULT_ADDR=https://vault.internal:8200
# VAULT_TOKEN=                        # admin token used ONLY to mint scoped child tokens
# VAULT_KV_MOUNT=secret               # KV v2 mount holding per-scope metadata
# VAULT_OWNER=community               # registry owner label shown by describe()

# --- Sandbox backend (Ticket 3/4) — strongest enforcement each host allows ----
# auto (default): gVisor if runsc is usable, else ProcessSandbox (laptop/CI).
# SANDBOX_BACKEND=auto                 # auto | gvisor | process
# SANDBOX_IMAGE=node:20-alpine         # guest image for the gVisor backend
# SANDBOX_EGRESS_NET=aigov-egress      # docker network whose only route out is the proxy

# --- LLM router (#1) — local-first: Ollama -> cloud (opt-in) -> stub ---------
# OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b         # used when Ollama is reachable; else falls back to the built-in stub
# OLLAMA_TIMEOUT_MS=20000
# Cloud tier is OFF by default and needs BOTH switches (ALLOW_CLOUD above = true
# AND a configured provider). An enclave keeps ALLOW_CLOUD=false, so it never
# reaches out. OpenAI-compatible /chat/completions (OpenAI, Together, vLLM, …):
# LLM_CLOUD_URL=https://api.openai.com/v1
# LLM_CLOUD_MODEL=gpt-4o-mini
# LLM_CLOUD_KEY=                 # set as a secret in prod; never in any client
# LLM_CLOUD_TIMEOUT_MS=30000

# --- Storage (dual): file ledger by default; Postgres when DATABASE_URL is set
# Enabling Postgres adds the one dependency `pg` (npm i pg) — opt-in, keeps the default dependency-free.
# DATABASE_URL=postgres://user:pass@host:5432/aigov
